__pycache__/
*.pyc
*.egg-info/
.venv/
venv/
.env
build/
dist/

# per-project data a consuming repo owns -- never this toolkit repo's own artifacts
compiled/
knowledge_base/
*-runs/
.deepresearch/

# live-model eval tier output -- run artifacts, not source (baseline is the
# one exception: a committed reference point for --compare, see Task 7)
eval-results/*
!eval-results/baseline.json

# Recipe-B final SFT dataset -- large train/val JSONL stay out of git; the
# provenance manifest (dataset_hash, component hashes, curation method) and the
# training-run provenance (run.json, merge status) are the committed reference
# points, mirroring eval-results/baseline.json. Data files stay out.
sft-final/*
!sft-final/manifest.json
!sft-final/provenance/
sft-final/provenance/*
!sft-final/provenance/*.json
!sft-final/provenance/*.txt
